# Copy this file to `.env` before running the service locally or with Docker.
#
# Local run:
#   uv sync
#   uv run python -m src.main
#
# Tests:
#   uv run pytest -q
#   uv run python -m compileall src example scripts tests
#
# Docker:
#   docker build -t crypto-info-mcp .
#   docker run --rm -p 8123:8123 --env-file .env crypto-info-mcp
#
# Docker Compose:
#   test -f .env || cp .env.example .env
#   docker network inspect bridge_server >/dev/null 2>&1 || docker network create bridge_server
#   docker compose up --build
#   Published MCP endpoint: http://127.0.0.1:18123/mcp
#
# Credentials:
#   COINGECKO_API_KEY is required for CoinGecko-backed tools.
#   Telegram variables are required for Telegram-backed tools.
#   Generate TELEGRAM_SESSION_STRING with:
#     uv run python scripts/generate_session.py
#   If Telegram variables are missing, market overview still runs without whale alerts.
VERSION=local
COINGECKO_API_KEY=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
